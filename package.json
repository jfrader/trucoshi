{
  "name": "trucoshi",
  "version": "15.0.4",
  "private": false,
  "packageManager": "yarn@1.22.22",
  "author": {
    "name": "jfrader",
    "email": "jfrader@pm.me",
    "url": "https://github.com/jfrader"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "yarn": "1.22.22"
  },
  "description": "Truco Game Server",
  "main": "dist/types.js",
  "types": "dist/types.d.ts",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrader/trucoshi.git"
  },
  "bugs": {
    "url": "https://github.com/jfrader/trucoshi/issues"
  },
  "homepage": "https://github.com/jfrader/trucoshi#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bitcoin",
    "lightning"
  ],
  "paths": {
    "trucoshi": [
      "./"
    ]
  },
  "scripts": {
    "clean": "rimraf ./build ./dist",
    "prisma:generate": "prisma generate",
    "typecheck": "yarn prisma:generate && tsc --noEmit --project .",
    "build": "yarn prisma:generate && rimraf ./build && tsc --project .",
    "build:dist": "yarn build:package-source",
    "build:package-source": "yarn --cwd source-build build",
    "start": "nodemon",
    "start:migrate": "prisma db push && yarn start",
    "start:prod": "node bin/trucoshi-server",
    "start:prod:migrate": "prisma migrate deploy && yarn start:prod",
    "docker": "NODE_ENV=development ./init-dev.sh",
    "dev:all": "NODE_ENV=development ./init-dev-all.sh",
    "dev:all:sudo-docker": "DEV_ALL_DOCKER_SUDO=1 NODE_ENV=development ./init-dev-all.sh",
    "docker:exec": "docker compose exec -i server yarn",
    "docker:prod": "NODE_ENV=production && docker compose -f docker-compose.prod.yml down && docker compose -f docker-compose.prod.yml --env-file .env up --build",
    "docker:staging": "docker compose -f docker-compose.staging.yml down && docker compose -f docker-compose.staging.yml --env-file .env up --build",
    "docker:e2e": "NODE_ENV=test ./init-e2e.sh",
    "test": "yarn prisma:generate && dotenv -e .env.test -- ts-mocha --exit ./test/lib/**/*.ts -t 50000",
    "test:e2e": "prisma db push --force-reset && dotenv -e .env.test -- ts-mocha --reporter spec --verbose --exit ./test/**/*.ts -t 60000",
    "profiler": "node --prof ./bin/trucoshi-server",
    "prepublishOnly": "yarn runtime:verify && yarn typecheck && yarn test && yarn build:dist",
    "cli:autoplay": "APP_DEBUG_LEVEL=warn yarn run ts-node src/utils/scripts/autoplay",
    "cli:play": "APP_DEBUG_LEVEL=warn yarn run ts-node src/utils/scripts/play",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "runtime:verify": "node scripts/verify-runtime-manifest.cjs",
    "source:install": "yarn --cwd source-build install --frozen-lockfile --modules-folder ../node_modules"
  },
  "devDependencies": {
    "@prisma/client": "6.19.2",
    "@socket.io/redis-adapter": "8.3.0",
    "@types/chai": "^5.2.3",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.memoize": "^4.1.9",
    "@types/lodash.partialright": "^4.2.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/mocha": "^10.0.1",
    "@types/node": "^24.12.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node-forge": "^1.3.14",
    "@types/sanitize-html": "^2.16.1",
    "@types/sinon": "^17.0.4",
    "axios": "^1.18.1",
    "chai": "^5.3.3",
    "dotenv": "^16.0.3",
    "form-data": "^4.0.6",
    "jsonwebtoken": "^9.0.3",
    "lightning-accounts": "7.0.1",
    "lodash.debounce": "^4.0.8",
    "lodash.memoize": "^4.1.2",
    "lodash.partialright": "^4.2.1",
    "lodash.throttle": "^4.1.1",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "dotenv-cli": "^7.3.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "prisma": "6.19.2",
    "redis": "5.7.0",
    "rimraf": "^6.1.3",
    "sanitize-html": "^2.17.1",
    "sinon": "^21.0.2",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.1",
    "typescript": "5.9.3"
  },
  "files": [
    "dist/lib/index.js",
    "dist/lib/index.d.ts",
    "dist/lib/constants.js",
    "dist/lib/constants.d.ts",
    "dist/lib/classes/index.js",
    "dist/lib/classes/index.d.ts",
    "dist/lib/classes/Deck.js",
    "dist/lib/classes/Deck.d.ts",
    "dist/lib/classes/Random.js",
    "dist/lib/classes/Random.d.ts",
    "dist/lib/classes/Table.js",
    "dist/lib/classes/Table.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/events.js",
    "dist/events.d.ts",
    "src/lib/index.ts",
    "src/lib/constants.ts",
    "src/lib/classes/index.ts",
    "src/lib/classes/Deck.ts",
    "src/lib/classes/Random.ts",
    "src/lib/classes/Table.ts",
    "src/types.ts",
    "src/events.ts",
    "source-build/package.json",
    "source-build/yarn.lock",
    "tsconfig.base.json",
    "tsconfig.package.json",
    ".nvmrc",
    "LICENSE"
  ],
  "dependencies": {
    "node-forge": "^1.3.3"
  },
  "resolutions": {
    "axios/form-data": "4.0.6",
    "defu": "6.1.7",
    "effect": "3.21.0",
    "js-yaml": "4.3.0",
    "brace-expansion": "5.0.6",
    "mocha/diff": "8.0.3",
    "mocha/serialize-javascript": "7.0.5",
    "nodemon/**/picomatch": "2.3.2",
    "path-to-regexp": "8.4.2",
    "postcss": "8.5.19",
    "qs": "6.15.3",
    "ws": "8.21.1"
  }
}
