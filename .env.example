NODE_ENV="development"
APP_DEBUG_LEVEL="trace"
APP_PORT=2992
APP_ORIGIN=http://localhost:2991

APP_DB_NAME="trucoshi_local"
APP_DB_USER="trucoshi_user"
APP_DB_PASSWORD="trucoshi_password"

# Overwritten by docker using credentials above
DATABASE_URL="postgresql://trucoshi_user:trucoshi_password@localhost:5432/trucoshi_local?schema=public"

APP_REDIS_URL="redis://localhost:6379"

APP_LIGHTNING_ACCOUNTS_URL="http://localhost:2999/v1"
APP_LIGHTNING_ACCOUNTS_JWT_PUBLIC_KEY="base64 encoded jwt public key"
APP_LIGHTNING_ACCOUNTS_EMAIL="admin@example.com"
APP_LIGHTNING_ACCOUNTS_PASSWORD="change me 123"
# Stable prefix shared with the compatible client for the identity cookie.
APP_LIGHTNING_ACCOUNTS_COOKIE_PREFIX=

# The complete development stack includes a ready regtest wallet. Re-evaluate
# this explicitly before using the same file in a shared or production setup.
APP_BETS_ENABLED=1

# Local development defaults. Replace both with different random values in any
# shared or production environment.
# Read/write bearer token for POST /ops/drain and POST /ops/resume.
APP_OPS_TOKEN="trucoshi-dev-ops-control-token"
# Separate read-only bearer token for GET /ops/status. The public web host gets
# only this value; never give it APP_OPS_TOKEN.
APP_OPS_STATUS_TOKEN="trucoshi-dev-ops-status-token"

#APP_CHEAT_CARDS="[[\"2o\",\"3o\",\"1o\"], [\"2e\",\"3e\",\"1e\"]]"
APP_CHEAT_LOTS_OF_FLOWERS_FOR_TESTING=0
APP_DISABLE_TURN_TIMER=0
APP_DISABLE_TIMERS=0
APP_SALT=randomsalt
APP_RAKE_PERCENT=0
# A positive cap is required whenever production bets are enabled.
APP_MAX_BET=1000
APP_PREVIOUS_HAND_ACK_TIMEOUT=
