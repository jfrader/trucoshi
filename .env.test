NODE_ENV="test"
APP_DEBUG_LEVEL="warn"
APP_PORT=3992
APP_ORIGIN=http://localhost:3991

APP_DB_NAME="trucoshi_local"
APP_DB_USER="trucoshi_user"
APP_DB_PASSWORD="trucoshi_password"

# Overwritten by docker using credentials above
DATABASE_URL="postgresql://trucoshi_user:trucoshi_password@localhost:5432/trucoshi_local?schema=public"

APP_REDIS_URL="redis://localhost:6379"

APP_LIGHTNING_ACCOUNTS_URL="http://localhost:3999/v1"
APP_LIGHTNING_ACCOUNTS_JWT_PUBLIC_KEY="dGVzdC1vbmx5"
APP_LIGHTNING_ACCOUNTS_EMAIL="test-admin@example.invalid"
APP_LIGHTNING_ACCOUNTS_PASSWORD="test-only-not-a-secret"
APP_LIGHTNING_ACCOUNTS_COOKIE_PREFIX=
APP_BETS_ENABLED=1
APP_OPS_TOKEN="test-ops-token"

APP_CHEAT_LOTS_OF_FLOWERS_FOR_TESTING=0
APP_DISABLE_TURN_TIMER=1
APP_DISABLE_TIMERS=1
APP_SALT=randomsalt
APP_RAKE_PERCENT=1
APP_MAX_BET=
