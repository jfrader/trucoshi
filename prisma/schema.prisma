generator client {
  provider = "prisma-client-js"
}

generator distClient {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserStats {
  id        Int  @id @default(autoincrement())
  accountId Int? @unique
  win       Int  @default(0)
  loss      Int  @default(0)
  elo       Int  @default(1000)
  satsBet   Int  @default(0)
  satsWon   Int  @default(0)
  satsLost  Int  @default(0)
}

model Match {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessionId      String
  state          EMatchState   @default(UNREADY)
  ownerAccountId Int?
  options        Json          @default("{}")
  createdFromQueue Boolean    @default(false)
  results        Json          @default("[{\"malas\": 0, \"buenas\": 0}, {\"malas\": 0, \"buenas\": 0}]")
  winnerIdx      Int?
  bet            MatchBet?
  hands          MatchHand[]
  players        MatchPlayer[]
  treasureCredits UserTreasureMatchCredit[]
  treasureChests  UserTreasureChest[]
}

model MatchBet {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  matchId        Int      @unique
  satsPerPlayer  Int
  allPlayersPaid Boolean
  winnerAwarded  Boolean
  refunded       Boolean  @default(false)
  match          Match    @relation(fields: [matchId], references: [id])
}

model MatchHand {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  idx             Int
  secret          String   @default("")
  clientSecrets   String[] @default([])
  rounds          Json     @default("[[]]")
  results         Json     @default("[0, 0]")
  matchId         Int
  trucoWinnerIdx  Int?
  envidoWinnerIdx Int?
  florWinnerIdx   Int?
  bitcoinHash     String   @default("")
  bitcoinHeight   Int      @default(0)
  match           Match    @relation(fields: [matchId], references: [id])
}

model MatchPlayer {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  idx          Int?
  name         String   @default("Satoshi")
  accountId    Int?
  session      String
  teamIdx      Int
  satsPaid     Int      @default(0)
  satsReceived Int      @default(0)
  payRequestId Int?
  bot          Boolean  @default(false)
  deckSkinByCard Json    @default("{}")
  matchId      Int
  match        Match    @relation(fields: [matchId], references: [id])
}

model CardSkin {
  id          String         @id
  release     String
  card        String
  description String?
  fileName    String
  assetPath   String
  rarity      CardSkinRarity @default(COMMON)
  enabled     Boolean        @default(true)
  unlockable  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userSkins UserCardSkin[]
  deckCards UserDeckCard[]
  treasureChests UserTreasureChest[]
  skinRollRewards UserSkinRoll[]

  @@index([release])
  @@index([card])
  @@index([enabled])
}

model UserCardSkin {
  id         Int      @id @default(autoincrement())
  accountId  Int
  cardSkinId String
  unlockedAt DateTime @default(now())
  source     String?
  quantity   Int      @default(1)

  cardSkin CardSkin @relation(fields: [cardSkinId], references: [id])

  @@unique([accountId, cardSkinId])
  @@index([accountId])
}

model UserSkinRoll {
  id               Int            @id @default(autoincrement())
  accountId        Int
  inputRarity      CardSkinRarity
  outputRarity     CardSkinRarity
  consumedSkinIds  Json
  rewardedSkinId   String
  createdAt        DateTime       @default(now())

  rewardedSkin CardSkin @relation(fields: [rewardedSkinId], references: [id])

  @@index([accountId])
  @@index([createdAt])
}

model UserDeckCard {
  id         Int      @id @default(autoincrement())
  accountId  Int
  card       String
  cardSkinId String
  updatedAt  DateTime @updatedAt

  cardSkin CardSkin @relation(fields: [cardSkinId], references: [id])

  @@unique([accountId, card])
  @@index([accountId])
}

model UserTreasureProgress {
  id        Int      @id @default(autoincrement())
  accountId Int     @unique
  progress  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTreasureMatchCredit {
  id         Int      @id @default(autoincrement())
  accountId  Int
  matchId    Int
  creditedAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])

  @@unique([accountId, matchId])
  @@index([accountId])
  @@index([matchId])
}

model UserTreasureChest {
  id            Int             @id @default(autoincrement())
  accountId     Int
  sourceMatchId Int?
  earnedAt      DateTime        @default(now())
  openedAt      DateTime?
  rolledRarity  CardSkinRarity?
  cardSkinId    String?
  duplicate     Boolean         @default(false)

  sourceMatch     Match?           @relation(fields: [sourceMatchId], references: [id])
  cardSkin        CardSkin?        @relation(fields: [cardSkinId], references: [id])
  adminRewardCode AdminRewardCode?

  @@index([accountId])
  @@index([sourceMatchId])
  @@index([openedAt])
}

model AdminRewardCode {
  id                  Int       @id @default(autoincrement())
  codeHash            String    @unique
  codePreview         String
  createdByAccountId  Int
  intendedAccountId   Int?
  note                String?
  createdAt           DateTime  @default(now())
  redeemedAt          DateTime?
  redeemedByAccountId Int?
  treasureChestId     Int?      @unique

  treasureChest UserTreasureChest? @relation(fields: [treasureChestId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([redeemedAt])
  @@index([redeemedByAccountId])
}

model AdminNoticeBanner {
  id                 Int      @id @default(autoincrement())
  text               String
  severity           String   @default("info")
  buttonText         String?
  buttonHref         String?
  active             Boolean  @default(true)
  updatedByAccountId Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([active])
  @@index([updatedAt])
}

enum EMatchState {
  UNREADY
  READY
  STARTED
  FINISHED
}

enum CardSkinRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  PROMO
}
