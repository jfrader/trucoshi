      "updated": 1,
      "link": null,
      "locked": false,
      "text": "UserSession stores disconnection and turn timeout promises. Trucoshi can pause, unpause, wait for reconnect, mark players abandoned, remove/kick players, refund paid entries, and cleanup match tables.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "UserSession stores disconnection and turn timeout promises. Trucoshi can pause, unpause, wait for reconnect, mark players abandoned, remove/kick players, refund paid entries, and cleanup match tables.",
      "autoResize": false,
      "lineHeight": 1.25
    },
