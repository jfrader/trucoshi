      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "On listen(), Trucoshi scans persisted matches with unpaid bets. It fetches accounts PayRequests and attempts refunds for players whose entry was paid but the match was not awarded or refunded.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On listen(), Trucoshi scans persisted matches with unpaid bets. It fetches accounts PayRequests and attempts refunds for players whose entry was paid but the match was not awarded or refunded.",
      "autoResize": false,
      "lineHeight": 1.25
    },
