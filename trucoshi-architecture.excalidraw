      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The client does not mutate game state directly. It receives callback functions in WAITING_PLAY and WAITING_POSSIBLE_SAY, stores them in useMatch state, and invokes them with { cardIdx, card } or { command }.",
      "fontSize": 12,
      "fontFamily": 1,
