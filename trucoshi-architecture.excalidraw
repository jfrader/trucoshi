      "locked": false,
      "text": "getPublicMatch generates a per-session view: current player sees private hand/commands/payRequestId; opponents receive public state and burnt hidden cards.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
