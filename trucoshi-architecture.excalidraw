      "link": null,
      "locked": false,
      "text": "Trucoshi stores external IDs instead of cross-database FKs:\n- Match.ownerAccountId -> accounts.User.id\n- MatchPlayer.accountId -> accounts.User.id\n- MatchPlayer.payRequestId -> accounts.PayRequest.id\n- UserStats.accountId -> accounts.User.id",
      "fontSize": 12,
      "fontFamily": 1,
