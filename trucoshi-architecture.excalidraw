      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Chat rooms are keyed by matchSessionId. Text CHAT messages are sanitized and persisted in room memory. SAY and game events can emit hidden sound messages for client playback.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chat rooms are keyed by matchSessionId. Text CHAT messages are sanitized and persisted in room memory. SAY and game events can emit hidden sound messages for client playback.",
