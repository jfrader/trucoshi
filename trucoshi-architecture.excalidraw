      "version": 1,
      "versionNonce": 200423,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "In 6-player matches, Match activates pica-pica at ceil(matchPoint * PICA_PICA_TRIGGER_PERCENT). It alternates pica/normal by tick, disables non-pair players for mini-hands, keeps normal forehand nextHand() rotation, and ends pica permanently on any abandoned player.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In 6-player matches, Match activates pica-pica at ceil(matchPoint * PICA_PICA_TRIGGER_PERCENT). It alternates pica/normal by tick, disables non-pair players for mini-hands, keeps normal forehand nextHand() rotation, and ends pica permanently on any abandoned player.",
      "autoResize": false,
      "lineHeight": 1.25
    }
